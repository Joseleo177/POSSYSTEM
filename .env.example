# ══════════════════════════════════════════════════════
#  POS SYSTEM — Variables de entorno
#  Copia este archivo a .env y ajusta los valores
#  cp .env.example .env
# ══════════════════════════════════════════════════════

# ── Base de datos ─────────────────────────────────────
POSTGRES_DB=posdb
POSTGRES_USER=posuser
POSTGRES_PASSWORD=pospassword

# ── Puertos expuestos en el host (cambia si hay conflicto)
POSTGRES_HOST_PORT=5432
BACKEND_PORT=4000
FRONTEND_PORT=3001

# ── Backend ───────────────────────────────────────────
NODE_ENV=development
JWT_SECRET=supersecretkey_change_in_production_please

# ── CORS (en producción pon tu dominio real) ──────────
CORS_ORIGIN=*

# ── Logging ───────────────────────────────────────────
LOG_LEVEL=info
