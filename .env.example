# =================================================================
#  POS SYSTEM — Configuración Docker Compose
#  Copia este archivo como .env y completa los valores
#  cp .env.example .env
# =================================================================

# ── Puertos expuestos en tu máquina ──────────────────────────────
FRONTEND_PORT=3001
BACKEND_PORT=4000
POSTGRES_HOST_PORT=5433      # Puerto en tu PC para acceso externo a la BD

# ── Base de datos LOCAL (PostgreSQL en Docker) ────────────────────
# Solo aplica cuando usas el contenedor `db` de docker-compose
POSTGRES_DB=posdb
POSTGRES_USER=posuser
POSTGRES_PASSWORD=cambia_esta_password_segura

# ── Seguridad ─────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_string_aleatorio_largo_min_32_chars
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────────
# En producción cambia * por tu dominio: https://tudominio.com
CORS_ORIGIN=*

# ── Supabase (SOLO si usas modo nube) ─────────────────────────────
# Si dejas estas en blanco, las imágenes se guardan en disco local
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_SERVICE_KEY=sb_secret_...

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=info
