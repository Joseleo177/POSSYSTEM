# ==========================================
# POS SYSTEM - ENVIRONMENT CONFIG
# ==========================================
# Copia este archivo como .env y completa los valores

# SERVER
PORT=4000
NODE_ENV=development

# CORS
CORS_ORIGIN=*

# DATABASE (local Docker o Supabase)
DB_HOST=localhost        # Docker: localhost | Supabase: aws-0-xx.pooler.supabase.com
DB_PORT=5432             # Docker: 5432      | Supabase Session Pooler: 6543
DB_USER=postgres
DB_PASSWORD=
DB_NAME=pos_db
DB_LOGGING=false

# SECURITY (JWT)
JWT_SECRET=cambia_esto_por_algo_seguro
JWT_EXPIRES_IN=12h

# LOGGING
LOG_LEVEL=info

# SUPABASE STORAGE (opcional — solo si usas Supabase)
# Si no defines estas variables, las imágenes se guardan en disco local (/uploads)
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_SERVICE_KEY=sb_secret_...
